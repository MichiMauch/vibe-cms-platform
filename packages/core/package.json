{
  "name": "@vibe-cms-platform/core",
  "version": "0.1.0",
  "description": "Vibe-CMS shared blocks, editor UI, renderer, helpers and templates.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": false,
  "files": [
    "src",
    "templates"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./blocks": "./src/blocks/index.ts",
    "./manager": "./src/manager/index.ts",
    "./renderer": "./src/renderer/index.ts",
    "./editors": "./src/editors/index.ts",
    "./components": "./src/components/index.ts",
    "./components/chatbot": "./src/components/chatbot/index.ts",
    "./components/seo": "./src/components/seo/index.ts",
    "./lib": "./src/lib/index.ts",
    "./lib/server": "./src/lib/server.ts",
    "./api": "./src/api/index.ts",
    "./api/save-content": "./src/api/save-content.ts",
    "./api/ai-rewrite": "./src/api/ai-rewrite.ts",
    "./api/chat": "./src/api/chat.ts",
    "./api/add-language": "./src/api/add-language.ts",
    "./i18n": "./src/i18n/index.ts",
    "./i18n/server": "./src/i18n/server.ts",
    "./types": "./src/types/index.ts",
    "./templates": "./templates/index.json",
    "./templates/*": "./templates/*.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "next": ">=15",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "dependencies": {
    "@tiptap/extension-link": "^3.23.4",
    "@tiptap/pm": "^3.23.4",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "lucide-react": "^1.14.0",
    "openai": "^6.37.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MichiMauch/vibe-cms-platform.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/MichiMauch/vibe-cms-platform#readme",
  "publishConfig": {
    "access": "public"
  }
}
